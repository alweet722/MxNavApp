<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NBNavApp.StartPage" >

    <Grid 
        RowSpacing="25" 
        Padding="30,25,30,25"  
        RowDefinitions="30,50,615,*"
        ColumnDefinitions="175,175">
        <Label 
            Grid.Row="0"
            Grid.ColumnSpan="2"
            x:Name="ConnDvc" 
            FontSize="Medium" 
            Text="Disconnected"
            VerticalOptions="Start"/>
        <Button 
            Grid.Row="1"
            Grid.Column="0"
            x:Name="ScanBtn" 
            Text="Scan" 
            Clicked="OnScanClicked" 
            WidthRequest="120" 
            HorizontalOptions="Start"/>
        <Button 
            Grid.Row="1"
            Grid.Column="1"
            x:Name="ConnectionToggleBtn" 
            Text="Connect" 
            Clicked="OnConnectionToggleClicked" 
            IsEnabled="False" 
            WidthRequest="120" 
            HorizontalOptions="End"/>
        <CollectionView
            Grid.Row="2"
            Grid.ColumnSpan="2"
            x:Name="Devices" 
            SelectionMode="Single" 
            SelectionChanged="OnDeviceSelected" >
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding Name}" FontAttributes="Bold"/>
                        <Label Text="{Binding Details}" FontSize="12"/>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup Name="CommonStates">
                                <VisualState Name="Normal"/>
                                <VisualState Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#AC99EA"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <ImageButton
            Grid.Row="3"
            Grid.Column="1"
            x:Name="NextPageBtn"
            Source="arrow_right.svg"
            BackgroundColor="#AC99EA"
            Clicked="OnNextPageClicked"
            IsVisible="False"
            HeightRequest="50" 
            WidthRequest="50" 
            CornerRadius="50" 
            HorizontalOptions="End"/>
    </Grid>
</ContentPage>
