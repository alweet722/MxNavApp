<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    x:Name="RoutePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    x:Class="NBNavApp.RoutePage"
    xmlns:vm="clr-namespace:NBNavApp.ViewModels"
    Title="Route">
    
    <Grid 
        Padding="30,25,30,25" 
        RowSpacing="10"
        RowDefinitions="30,50,30,50,30,30,50,*,20,20,50" 
        ColumnDefinitions="145,*" 
        HorizontalOptions="Fill">
        <Label 
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Text="Start" 
            FontSize="Medium" />
        <Entry 
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Placeholder="Start address or coordinates"
            FontSize="18"
            Text="{Binding StartAddressText, Mode=TwoWay}"
            ReturnCommand="{Binding StartAddressCompletedCommand}"/>
        <Label 
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Text="Destination" 
            FontSize="Medium" />
        <Entry 
            Grid.Row="3"
            Grid.ColumnSpan="2"
            Placeholder="Destination address or coordinates"
            FontSize="18"
            Text="{Binding DestAddressText, Mode=TwoWay}"
            ReturnCommand="{Binding DestAddressCompletedCommand}"/>
        <Label
            Grid.Row="4"
            Grid.Column="0"
            Text="Avoid highways"
            FontSize="18" />
        <Switch
            Grid.Row="4"
            Grid.Column="1"
            x:Name="AvoidHighwaysSw"
            IsToggled="{Binding AvoidHighways}"/>
        <Label
            Grid.Row="5"
            Grid.Column="0"
            Text="Avoid toll roads"
            FontSize="18" />
        <Switch
            Grid.Row="5"
            Grid.Column="1"
            x:Name="AvoidTollSw"
            IsToggled="{Binding AvoidToll}"/>
        <Button
            Grid.Row="6"
            Grid.ColumnSpan="2"
            Text="Route"
            Command="{Binding RouteCommand}"
            HorizontalOptions="Fill"/>
        <mapsui:MapControl
            Grid.Row="7"
            Grid.ColumnSpan="2"
            Map="{Binding Map}"/>
        <Label
            Grid.Row="8"
            Grid.Column="0"
            Text="Distance:"
            FontSize="14"/>
        <Label
            Grid.Row="9"
            Grid.Column="0"
            Text="Time to destination:"
            FontSize="14"/>
        <Label
            Grid.Row="8"
            Grid.Column="1"
            Text="{Binding DistToDestText}"
            FontSize="14"
            HorizontalOptions="End"/>
        <Label
            Grid.Row="9"
            Grid.Column="1"
            Text="{Binding TimeToDestText}"
            FontSize="14"
            HorizontalOptions="End"/>
        <Button
            Grid.Row="10"
            Grid.Column="0"
            Text="Drive"
            Command="{Binding DriveCommand}"
            HorizontalOptions="Start"
            WidthRequest="120"/>
        <Button
            Grid.Row="10"
            Grid.Column="1"
            Text="Stop"
            Command="{Binding StopCommand}"
            HorizontalOptions="End"
            WidthRequest="120"/>
    </Grid>
</ContentPage>